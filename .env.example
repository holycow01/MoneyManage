# Supabase (public — exposed to client)
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# Drizzle (server / dev only — never imported from client code)
DATABASE_URL=postgres://postgres:[password]@db.xxx.supabase.co:5432/postgres

# Anthropic — only needed if you want AI insights / NL search.
# Set as a Supabase Edge Function secret, NOT in this .env:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxx
