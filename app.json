{
  "expo": {
    "name": "pulse",
    "slug": "pulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "pulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulse.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Pulse uses Face ID to unlock your financial data."
      }
    },
    "android": {
      "package": "com.pulse.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090b",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pulse to use Face ID to unlock your financial data."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10b981"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "185c358f-bbba-45d5-9c30-5d18779c1077"
      }
    }
  }
}
