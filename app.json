{
  "expo": {
    "name": "pulse",
    "slug": "pulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "pulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulse.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Pulse uses Face ID to unlock your financial data."
      }
    },
    "android": {
      "package": "com.pulse.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pulse to use Face ID to unlock your financial data."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10b981"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
